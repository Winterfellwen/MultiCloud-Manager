# ============================================================
# CloudOps AI Platform - 环境变量模板
# ============================================================
# 复制此文件为 .env，然后根据实际部署平台修改（Docker Compose / Render / K8s
#
# 三个平台的配置差异：
# - Docker Compose: 使用 docker-compose.yml 中的 .env 文件
# - Render:          使用 render.yaml 中声明的 envVars（或在 Render 面板中手动设置
# - Kubernetes:     使用 k8s/01-configmap.yaml + k8s/02-secret.yaml
#
# 核心原则：所有平台共享同一套 DATABASE_URL / REDIS_URL / JWT_SECRET
# 只是来源不同（Host vs 服务名 vs Secret
# ============================================================

# ============ 数据库与缓存（必选 ============
# Docker Compose: postgres:5432 / redis:6379
# Render:        Render Postgres + Redis 连接字符串
# Kubernetes:   postgres:5432 / redis:6379
DATABASE_URL=postgresql://cloudops:changeme@postgres:5432/cloudops
REDIS_URL=redis://redis:6379

# ============ JWT（必选 ============
# 生产环境必须是一个长随机字符串（建议 64+ 字符）
# 生成方法：openssl rand -hex 32
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=24h

# ============ 初始管理员 ============
# 首次部署时：
#   ADMIN_USERNAME: 用户名（默认 admin
#   ADMIN_PASSWORD: 留空时，首次启动会在容器日志中打印随机生成的密码
#   设置密码后，修改此变量会同步更新密码
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ============ 云服务商凭据（可选 ============
# AWS
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# 阿里云
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=

# Azure
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# Render API（用于在应用内管理 Render 资源
RENDER_API_KEY=

# ============ LLM（可选 ============
# 支持 OpenAI 兼容的 API（OpenAI / Anthropic Claude / DeepSeek / 自研模型等
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ============ Agent 配置（可选 ============
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT_MS=120000

# ============ Docker Compose 专用（可选 ============
# Web 应用端口映射（默认 80
APP_PORT=80
