# MultiCloud Platform Environment Configuration
# Copy this file to .env and update the values

# === Security (REQUIRED in production) ===
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
ADMIN_PASSWORD=your-secure-admin-password

# === Database ===
# For Docker Compose, these are auto-configured.
# For external DB, set DATABASE_URL directly.
# DATABASE_URL=postgres://user:pass@host:5432/dbname?sslmode=disable

# === Redis ===
# REDIS_URL=localhost:6379

# === AI Provider ===
# Set your AI API key here or via the Model Hub UI
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=sk-...

# === Cloud Provider Credentials ===
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1
# ALICLOUD_ACCESS_KEY=...
# ALICLOUD_SECRET_KEY=...
# ALICLOUD_REGION=cn-hangzhou
# TENCENT_SECRET_ID=...
# TENCENT_SECRET_KEY=...
# TENCENT_REGION=ap-guangzhou
# HUAWEI_ACCESS_KEY=...
# HUAWEI_SECRET_KEY=...
# HUAWEI_REGION=cn-north-4
