.cloud-selector {
  padding: 20rpx;
}

.selector-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text);
  margin-bottom: 24rpx;
  text-align: center;
}

.cloud-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  justify-content: center;
}

.cloud-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 160rpx;
  height: 160rpx;
  border-radius: var(--radius-lg);
  background-color: var(--bg);
  border: 2rpx solid var(--border);
  transition: all 0.2s ease;
}

.cloud-item.active {
  background-color: var(--primary);
  border-color: var(--primary);
}

.cloud-item.active .cloud-name {
  color: #ffffff;
}

.cloud-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.cloud-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}
