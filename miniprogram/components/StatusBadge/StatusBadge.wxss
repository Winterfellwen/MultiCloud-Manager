.status-badge {
  display: inline-block;
  padding: 4px 8px;
  border-radius: 12px;
  font-size: 12px;
  line-height: 1;
}

.status-normal {
  background-color: var(--surface-hover);
  color: var(--text-secondary);
}

.status-success {
  background-color: rgba(34, 197, 94, 0.15);
  color: var(--success);
}

.status-warning {
  background-color: rgba(245, 158, 11, 0.15);
  color: var(--warning);
}

.status-error {
  background-color: rgba(239, 68, 68, 0.15);
  color: var(--danger);
}
