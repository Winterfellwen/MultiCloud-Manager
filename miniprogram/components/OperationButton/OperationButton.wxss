.operation-btn {
  padding: 8px 16px;
  border-radius: 4px;
  font-size: 14px;
  border: 1rpx solid var(--border);
  background: var(--surface);
  color: var(--text);
}

.type-primary {
  background: var(--primary);
  color: #fff;
  border-color: var(--primary);
}

.type-danger {
  background: var(--danger);
  color: #fff;
  border-color: var(--danger);
}

.operation-btn[disabled] {
  opacity: 0.5;
}
