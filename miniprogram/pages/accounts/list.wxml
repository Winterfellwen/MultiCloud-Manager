<view class="container theme-{{theme}}">
  <view class="page-header">
    <text class="page-title">{{lang.acc_list_title}}</text>
    <navigator url="/pages/accounts/add" class="btn-add">{{lang.acc_add}}</navigator>
  </view>

  <view class="account-list">
    <view class="account-card" wx:for="{{accounts}}" wx:key="id">
      <view class="account-info">
        <view class="account-icon {{'cloud-' + item.provider}}">
          <text wx:if="{{item.provider === 'azure'}}">☁️</text>
          <text wx:elif="{{item.provider === 'tencent'}}">🌐</text>
          <text wx:elif="{{item.provider === 'oracle'}}">🔶</text>
          <text wx:elif="{{item.provider === 'render'}}">⚡</text>
        </view>
        <view class="account-detail">
          <text class="account-name">{{item.name}}</text>
          <text class="account-provider">{{item.providerLabel}}</text>
        </view>
      </view>
      <view class="account-actions">
        <status-badge status="{{item.status === 'active' ? 'success' : 'error'}}" text="{{item.status === 'active' ? lang.acc_connected : lang.acc_error}}"></status-badge>
        <button class="btn-delete" bindtap="onDelete" data-id="{{item.id}}">{{lang.acc_delete}}</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{accounts.length === 0}}">
    <text class="empty-icon">📋</text>
    <text class="empty-text">{{lang.acc_empty}}</text>
    <text class="empty-hint">{{lang.acc_empty_hint}}</text>
  </view>
</view>
