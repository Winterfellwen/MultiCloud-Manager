<view class="container theme-{{theme}}">
  <view class="page-header">
    <text class="page-title">{{lang.acc_add_title}}</text>
  </view>

  <view class="form-card">
    <view class="form-group">
      <text class="form-label">{{lang.acc_cloud_label}}</text>
      <cloud-selector bind:select="onCloudSelect"></cloud-selector>
    </view>

    <view class="form-group">
      <text class="form-label">{{lang.acc_name_label}}</text>
      <input class="form-input" placeholder="{{lang.acc_name_placeholder}}" value="{{accountName}}" bindinput="onNameInput"/>
    </view>

    <view class="form-group">
      <text class="form-label">{{lang.acc_access_key}}</text>
      <input class="form-input" placeholder="{{lang.acc_access_placeholder}}" value="{{accessKey}}" bindinput="onAccessKeyInput"/>
    </view>

    <view class="form-group">
      <text class="form-label">{{lang.acc_secret_key}}</text>
      <input class="form-input" type="password" placeholder="{{lang.acc_secret_placeholder}}" value="{{secretKey}}" bindinput="onSecretKeyInput"/>
    </view>

    <view class="form-group">
      <text class="form-label">{{lang.acc_region_label}}</text>
      <input class="form-input" placeholder="{{lang.acc_region_placeholder}}" value="{{region}}" bindinput="onRegionInput"/>
    </view>
  </view>

  <button class="btn-submit" bindtap="onSubmit" disabled="{{!canSubmit}}">{{lang.acc_save}}</button>
</view>
