.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); }
.btn-add { background: var(--primary); color: #fff; padding: 16rpx 32rpx; border-radius: var(--radius-sm); font-size: 26rpx; }
.account-card { background: var(--surface); border-radius: var(--radius); padding: 24rpx; margin-bottom: 20rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: var(--shadow); }
.account-info { display: flex; align-items: center; gap: 20rpx; flex: 1; }
.account-icon { width: 72rpx; height: 72rpx; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 36rpx; }
.cloud-azure { background: rgba(0, 120, 212, 0.15); }
.cloud-tencent { background: rgba(0, 164, 255, 0.15); }
.cloud-oracle { background: rgba(248, 0, 0, 0.15); }
.cloud-render { background: rgba(70, 227, 183, 0.15); }
.account-detail { display: flex; flex-direction: column; gap: 6rpx; }
.account-name { font-size: 30rpx; font-weight: 600; color: var(--text); }
.account-provider { font-size: 24rpx; color: var(--text-secondary); }
.account-actions { display: flex; align-items: center; gap: 16rpx; }
.btn-delete { background: transparent; border: 1rpx solid var(--danger); color: var(--danger); padding: 8rpx 20rpx; border-radius: var(--radius-sm); font-size: 24rpx; line-height: 1; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--text-secondary); }
