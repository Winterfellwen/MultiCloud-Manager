.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); }
.form-card { background: var(--surface); border-radius: var(--radius); padding: 30rpx; margin-bottom: 30rpx; box-shadow: var(--shadow); }
.form-group { margin-bottom: 30rpx; }
.form-label { display: block; font-size: 28rpx; color: var(--text); margin-bottom: 12rpx; font-weight: 500; }
.form-input { width: 100%; height: 88rpx; line-height: 88rpx; padding: 0 20rpx; background: var(--bg); border: 1rpx solid var(--border); border-radius: var(--radius-sm); font-size: 28rpx; color: var(--text); box-sizing: border-box; }
.btn-submit { width: 100%; background: var(--primary); color: #fff; border: none; border-radius: var(--radius-sm); padding: 24rpx; font-size: 30rpx; font-weight: 500; }
.btn-submit[disabled] { opacity: 0.5; }
