<view class="container theme-{{theme}}">
  <view class="header">
    <text class="title">{{lang.home_title}}</text>
    <text class="subtitle">{{lang.home_subtitle}}</text>
  </view>

  <view class="stats-section">
    <view class="stat-card" wx:for="{{stats}}" wx:key="title">
      <text class="stat-value">{{item.value}}</text>
      <text class="stat-label">{{item.title}}</text>
    </view>
  </view>

  <view class="quick-actions">
    <text class="section-title">{{lang.home_quick_actions}}</text>
    <view class="action-grid">
      <navigator url="/pages/resources/list" class="action-item">
        <text class="action-icon">☁️</text>
        <text class="action-text">{{lang.home_resources}}</text>
      </navigator>
      <navigator url="/pages/accounts/list" class="action-item">
        <text class="action-icon">👤</text>
        <text class="action-text">{{lang.home_accounts}}</text>
      </navigator>
      <navigator url="/pages/terraform/list" class="action-item">
        <text class="action-icon">📦</text>
        <text class="action-text">{{lang.home_terraform}}</text>
      </navigator>
      <navigator url="/pages/team/members" class="action-item">
        <text class="action-icon">👥</text>
        <text class="action-text">{{lang.home_team}}</text>
      </navigator>
    </view>
  </view>

  <view class="recent-section" wx:if="{{recentResources.length > 0}}">
    <text class="section-title">{{lang.home_recent}}</text>
    <view class="resource-list">
      <view class="resource-item" wx:for="{{recentResources}}" wx:key="id">
        <text class="resource-name">{{item.name}}</text>
        <text class="resource-provider">{{item.provider}}</text>
      </view>
    </view>
  </view>

  <view class="activity-section">
    <text class="section-title">{{lang.home_activity}}</text>
    <view class="activity-list" wx:if="{{activities.length > 0}}">
      <view class="activity-item" wx:for="{{activities}}" wx:key="id">
        <text class="activity-icon">
          <block wx:if="{{item.action === 'create'}}">➕</block>
          <block wx:elif="{{item.action === 'start'}}">▶️</block>
          <block wx:elif="{{item.action === 'stop'}}">⏹️</block>
          <block wx:elif="{{item.action === 'delete'}}">🗑️</block>
          <block wx:elif="{{item.action === 'sync'}}">🔄</block>
          <block wx:else>📋</block>
        </text>
        <view class="activity-body">
          <text class="activity-desc">{{item.description || item.message}}</text>
          <text class="activity-time">{{item.created_at || item.time}}</text>
        </view>
      </view>
    </view>
    <view class="activity-empty" wx:else>
      <text class="empty-text">{{lang.home_activity_empty}}</text>
    </view>
  </view>
</view>
