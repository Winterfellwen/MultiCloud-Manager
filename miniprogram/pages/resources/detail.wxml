<view class="container theme-{{theme}}">
  <view class="page-header">
    <navigator url="/pages/resources/list" class="btn-back">{{lang.res_back}}</navigator>
    <text class="page-title">{{lang.res_detail_title}}</text>
  </view>

  <view class="detail-card">
    <view class="detail-row">
      <text class="detail-label">{{lang.res_name}}</text>
      <text class="detail-value">{{resource.name || '—'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">{{lang.res_cloud}}</text>
      <text class="detail-value">{{resource.providerLabel || '—'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">{{lang.res_status}}</text>
      <status-badge status="{{resource.status === 'running' ? 'success' : 'warning'}}" text="{{resource.status}}"></status-badge>
    </view>
    <view class="detail-row">
      <text class="detail-label">{{lang.res_region_label}}</text>
      <text class="detail-value">{{resource.region || '—'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">{{lang.res_spec_label}}</text>
      <text class="detail-value">{{resource.spec || '—'}}</text>
    </view>
    <view class="detail-row">
      <text class="detail-label">{{lang.res_created_at}}</text>
      <text class="detail-value">{{resource.createdAt || '—'}}</text>
    </view>
  </view>

  <view class="action-bar">
    <button class="btn-action btn-start" wx:if="{{resource.status === 'stopped'}}" bindtap="onStart">{{lang.res_start_resource}}</button>
    <button class="btn-action btn-stop" wx:if="{{resource.status === 'running'}}" bindtap="onStop">{{lang.res_stop_resource}}</button>
    <button class="btn-action btn-delete" bindtap="onDelete">{{lang.res_delete_resource}}</button>
  </view>
</view>
