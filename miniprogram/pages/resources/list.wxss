.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { margin-bottom: 24rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); }
.filter-bar { display: flex; gap: 16rpx; margin-bottom: 24rpx; }
.filter-picker { flex: 1; }
.filter-display { background: var(--surface); border: 1rpx solid var(--border); border-radius: var(--radius-sm); padding: 16rpx 20rpx; font-size: 26rpx; color: var(--text); text-align: center; }
.resource-card { background: var(--surface); border-radius: var(--radius); padding: 24rpx; margin-bottom: 20rpx; box-shadow: var(--shadow); }
.card-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 16rpx; }
.resource-info { flex: 1; }
.resource-name { font-size: 30rpx; font-weight: 600; color: var(--text); display: block; margin-bottom: 12rpx; }
.resource-tags { display: flex; gap: 12rpx; align-items: center; }
.tag { font-size: 22rpx; color: #fff; padding: 4rpx 14rpx; border-radius: var(--radius-sm); }
.tag-azure { background: var(--azure); }
.tag-tencent { background: var(--tencent); }
.tag-oracle { background: var(--oracle); }
.tag-render { background: var(--render); }
.resource-actions { display: flex; gap: 12rpx; }
.btn-action { font-size: 24rpx; padding: 8rpx 20rpx; border-radius: var(--radius-sm); line-height: 1; }
.btn-start { background: var(--success); color: #fff; border: none; }
.btn-stop { background: var(--warning); color: #fff; border: none; }
.card-meta { display: flex; gap: 24rpx; padding-top: 16rpx; border-top: 1rpx solid var(--border); }
.meta-item { font-size: 24rpx; color: var(--text-secondary); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--text-secondary); }
