<view class="container theme-{{theme}}">
  <view class="page-header">
    <text class="page-title">{{lang.res_list_title}}</text>
  </view>

  <view class="search-sync-bar">
    <input class="search-input" placeholder="{{lang.res_search_placeholder}}" value="{{searchText}}" bindinput="onSearchInput"/>
    <button class="sync-btn {{isSyncing ? 'syncing' : ''}}" bindtap="syncResources" disabled="{{isSyncing}}">{{isSyncing ? lang.res_syncing : lang.res_sync}}</button>
  </view>
  <view class="sync-status" wx:if="{{lastSyncTime}}">
    <text class="sync-label">{{lastSyncLabel}}</text>
  </view>

  <view class="filter-bar">
    <picker class="filter-picker" value="{{cloudIndex}}" range="{{cloudTypes}}" bindchange="onCloudFilter">
      <view class="filter-display">{{cloudTypes[cloudIndex]}} ▼</view>
    </picker>
    <picker class="filter-picker" value="{{statusIndex}}" range="{{statusTypes}}" bindchange="onStatusFilter">
      <view class="filter-display">{{statusTypes[statusIndex]}} ▼</view>
    </picker>
  </view>

  <view class="resource-list">
    <view class="resource-card" wx:for="{{filteredResources}}" wx:key="id">
      <navigator url="/pages/resources/detail?id={{item.id}}" class="card-top">
        <view class="resource-info">
          <text class="resource-name">{{item.name}}</text>
          <view class="resource-tags">
            <text class="tag tag-{{item.provider}}">{{item.providerLabel}}</text>
            <status-badge status="{{item.status === 'running' ? 'success' : 'warning'}}" text="{{item.status === 'running' ? lang.res_running : lang.res_stopped}}"></status-badge>
          </view>
        </view>
      </navigator>
      <view class="card-meta">
        <text class="meta-item">{{lang.res_region}} {{item.region}}</text>
        <text class="meta-item">{{lang.res_spec}} {{item.spec}}</text>
      </view>
      <view class="resource-actions">
        <button class="btn-action btn-start" wx:if="{{item.status !== 'running'}}" data-id="{{item.id}}" bindtap="startResource">{{lang.res_start}}</button>
        <button class="btn-action btn-stop" wx:if="{{item.status === 'running'}}" data-id="{{item.id}}" bindtap="stopResource">{{lang.res_stop}}</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{filteredResources.length === 0}}">
    <text class="empty-icon">☁️</text>
    <text class="empty-text">{{lang.res_empty}}</text>
    <text class="empty-hint">{{lang.res_empty_hint}}</text>
  </view>
</view>
