.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); }
.btn-upload { background: var(--primary); color: #fff; padding: 16rpx 32rpx; border-radius: var(--radius-sm); font-size: 26rpx; }
.tf-card { background: var(--surface); border-radius: var(--radius); padding: 24rpx; margin-bottom: 16rpx; display: flex; justify-content: space-between; align-items: center; box-shadow: var(--shadow); }
.tf-info { display: flex; flex-direction: column; gap: 6rpx; }
.tf-name { font-size: 30rpx; font-weight: 600; color: var(--text); }
.tf-provider { font-size: 24rpx; color: var(--text-secondary); }
.tf-meta { display: flex; align-items: center; gap: 16rpx; }
.tf-date { font-size: 22rpx; color: var(--text-secondary); }
.btn-apply { background: var(--success); color: #fff; padding: 8rpx 20rpx; border-radius: var(--radius-sm); font-size: 24rpx; border: none; line-height: 1; }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--text-secondary); }
