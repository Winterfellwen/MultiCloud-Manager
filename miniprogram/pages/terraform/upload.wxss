.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { display: flex; align-items: center; gap: 20rpx; margin-bottom: 30rpx; }
.btn-back { font-size: 28rpx; color: var(--primary); padding: 8rpx 0; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); flex: 1; }
.upload-card { background: var(--surface); border-radius: var(--radius); padding: 30rpx; margin-bottom: 24rpx; box-shadow: var(--shadow); }
.upload-area { border: 2rpx dashed var(--border); border-radius: var(--radius); padding: 60rpx 30rpx; display: flex; flex-direction: column; align-items: center; gap: 16rpx; }
.upload-icon { font-size: 64rpx; }
.upload-text { font-size: 28rpx; color: var(--text); }
.upload-hint { font-size: 22rpx; color: var(--text-secondary); }
.form-card { background: var(--surface); border-radius: var(--radius); padding: 30rpx; margin-bottom: 24rpx; box-shadow: var(--shadow); }
.form-group { margin-bottom: 24rpx; }
.form-label { display: block; font-size: 28rpx; color: var(--text); margin-bottom: 12rpx; font-weight: 500; }
.form-input { width: 100%; background: var(--bg); border: 1rpx solid var(--border); border-radius: var(--radius-sm); padding: 20rpx; font-size: 28rpx; color: var(--text); box-sizing: border-box; }
.form-picker { width: 100%; }
.picker-display { background: var(--bg); border: 1rpx solid var(--border); border-radius: var(--radius-sm); padding: 20rpx; font-size: 28rpx; color: var(--text); }
.btn-submit { width: 100%; background: var(--primary); color: #fff; border: none; border-radius: var(--radius-sm); padding: 24rpx; font-size: 30rpx; font-weight: 500; }
