<view class="container">
  <view class="page-header">
    <navigator url="/pages/terraform/list" class="btn-back">← 返回</navigator>
    <text class="page-title">上传配置</text>
  </view>

  <view class="upload-card">
    <view class="upload-area" bindtap="onPickFile">
      <text class="upload-icon">📁</text>
      <text class="upload-text">{{fileName || '点击选择 .tf 文件'}}</text>
      <text class="upload-hint">支持 .tf 和 .tfvars 格式</text>
    </view>
  </view>

  <view class="form-card" wx:if="{{fileName}}">
    <view class="form-group">
      <text class="form-label">配置名称</text>
      <input class="form-input" placeholder="请输入配置名称" value="{{configName}}" bindinput="onNameInput"/>
    </view>
    <view class="form-group">
      <text class="form-label">云平台</text>
      <picker class="form-picker" value="{{providerIndex}}" range="{{providers}}" bindchange="onProviderChange">
        <view class="picker-display">{{providers[providerIndex]}} ▼</view>
      </picker>
    </view>
  </view>

  <button class="btn-submit" wx:if="{{fileName}}" bindtap="onUpload">上传配置</button>
</view>
