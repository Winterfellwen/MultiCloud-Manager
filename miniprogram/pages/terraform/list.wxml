<view class="container theme-{{theme}}">
  <view class="page-header">
    <text class="page-title">{{lang.tf_list_title}}</text>
    <navigator url="/pages/terraform/upload" class="btn-upload">{{lang.tf_upload}}</navigator>
  </view>

  <view class="tf-list">
    <view class="tf-card" wx:for="{{configs}}" wx:key="id">
      <view class="tf-info">
        <text class="tf-name">{{item.name}}</text>
        <text class="tf-provider">{{item.provider}}</text>
      </view>
      <view class="tf-meta">
        <text class="tf-date">{{item.updatedAt}}</text>
        <button class="btn-apply" bindtap="onApply" data-id="{{item.id}}">{{lang.tf_deploy}}</button>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{configs.length === 0}}">
    <text class="empty-icon">📦</text>
    <text class="empty-text">{{lang.tf_empty}}</text>
    <text class="empty-hint">{{lang.tf_empty_hint}}</text>
  </view>
</view>
