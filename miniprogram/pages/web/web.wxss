page {
  height: 100%;
  background: #0c0c0e;
}

.state-panel {
  height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  padding: 24px;
  background: #0c0c0e;
}

.state-text {
  color: #a1a1a6;
  font-size: 14px;
  text-align: center;
  line-height: 1.6;
}

.retry-btn {
  background: #007aff;
  color: #fff;
  font-size: 14px;
  border-radius: 4px;
  padding: 0 24px;
  line-height: 2.4;
}

.retry-btn::after {
  border: none;
}
