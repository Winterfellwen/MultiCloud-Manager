.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.profile-header { display: flex; flex-direction: column; align-items: center; padding: 40rpx 0; }
.avatar { width: 120rpx; height: 120rpx; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 48rpx; font-weight: 600; margin-bottom: 20rpx; }
.user-name { font-size: 36rpx; font-weight: bold; color: var(--text); margin-bottom: 8rpx; }
.user-email { font-size: 26rpx; color: var(--text-secondary); }
.settings-card { background: var(--surface); border-radius: var(--radius); margin-bottom: 24rpx; overflow: hidden; box-shadow: var(--shadow); }
.setting-item { display: flex; justify-content: space-between; align-items: center; padding: 24rpx 30rpx; border-bottom: 1rpx solid var(--border); }
.setting-item:last-child { border-bottom: none; }
.setting-label { font-size: 28rpx; color: var(--text); }
.setting-value { font-size: 26rpx; color: var(--text-secondary); }
.setting-arrow { font-size: 36rpx; color: var(--text-secondary); }
.nav-item:active { background: var(--surface-hover); }
.about-card { background: var(--surface); border-radius: var(--radius); margin-bottom: 30rpx; box-shadow: var(--shadow); }
.btn-logout { width: 100%; background: transparent; border: 1rpx solid var(--danger); color: var(--danger); padding: 22rpx; border-radius: var(--radius-sm); font-size: 28rpx; font-weight: 500; margin-top: 20rpx; }
