<view class="container theme-{{theme}}">
  <view class="page-header">
    <text class="page-title">{{lang.team_title}}</text>
    <button class="btn-invite" bindtap="onInvite">{{lang.team_invite}}</button>
  </view>

  <view class="member-list">
    <view class="member-card" wx:for="{{members}}" wx:key="id">
      <view class="member-avatar">{{item.name ? item.name[0] : '?'}}</view>
      <view class="member-info">
        <text class="member-name">{{item.name}}</text>
        <text class="member-role">{{item.role}}</text>
      </view>
      <status-badge status="{{item.status === 'active' ? 'success' : 'normal'}}" text="{{item.status === 'active' ? lang.team_online : lang.team_offline}}"></status-badge>
    </view>
  </view>

  <view class="empty-state" wx:if="{{members.length === 0}}">
    <text class="empty-icon">👥</text>
    <text class="empty-text">{{lang.team_empty}}</text>
    <text class="empty-hint">{{lang.team_empty_hint}}</text>
  </view>
</view>
