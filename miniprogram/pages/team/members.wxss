.container { padding: 30rpx; background: var(--bg); min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 30rpx; }
.page-title { font-size: 40rpx; font-weight: bold; color: var(--text); }
.btn-invite { background: var(--primary); color: #fff; padding: 16rpx 32rpx; border-radius: var(--radius-sm); font-size: 26rpx; border: none; }
.member-card { background: var(--surface); border-radius: var(--radius); padding: 24rpx; margin-bottom: 16rpx; display: flex; align-items: center; gap: 20rpx; box-shadow: var(--shadow); }
.member-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; background: var(--primary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 600; flex-shrink: 0; }
.member-info { flex: 1; display: flex; flex-direction: column; gap: 6rpx; }
.member-name { font-size: 30rpx; font-weight: 600; color: var(--text); }
.member-role { font-size: 24rpx; color: var(--text-secondary); }
.empty-state { display: flex; flex-direction: column; align-items: center; padding: 80rpx 0; }
.empty-icon { font-size: 80rpx; margin-bottom: 24rpx; }
.empty-text { font-size: 30rpx; color: var(--text); margin-bottom: 12rpx; }
.empty-hint { font-size: 24rpx; color: var(--text-secondary); }
