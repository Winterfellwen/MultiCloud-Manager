/* pages/agent/chat.wxss - AI Agent 对话样式 */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: #f5f5f5;
}

/* 头部 */
.chat-header {
  background: #1890ff;
  color: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
}

.mode-picker {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.mode-display {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.icon-arrow {
  font-size: 20rpx;
  opacity: 0.8;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.messages {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

/* 消息气泡 */
.message {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar {
  order: 2;
}

.ai-avatar {
  order: 1;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.user-bubble {
  background: #1890ff;
  color: white;
  border-bottom-right-radius: 4rpx;
  order: 1;
}

.ai-bubble {
  background: white;
  color: #333;
  border-bottom-left-radius: 4rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  order: 2;
}

/* 计划卡片 */
.plan-card {
  margin-top: 20rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 16rpx;
  padding: 20rpx;
  background: #fafafa;
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid #eee;
}

.plan-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.plan-risk {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.plan-risk.high {
  background: #ff4d4f;
  color: white;
}

.plan-risk.medium {
  background: #faad14;
  color: white;
}

.plan-risk.low {
  background: #52c41a;
  color: white;
}

/* 步骤列表 */
.steps-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.step-item {
  background: white;
  border-radius: 12rpx;
  padding: 16rpx;
  border-left: 8rpx solid #d9d9d9;
}

.step-item.high {
  border-left-color: #ff4d4f;
}

.step-item.medium {
  border-left-color: #faad14;
}

.step-item.low {
  border-left-color: #52c41a;
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.step-index {
  font-size: 24rpx;
  color: #666;
}

.step-action {
  font-size: 26rpx;
  font-weight: 500;
  color: #333;
}

.step-details {
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
  word-break: break-all;
}

.step-risk {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.step-risk.high {
  background: #fff2f0;
  color: #ff4d4f;
  border: 1rpx solid #ffccc7;
}

.step-risk.medium {
  background: #fffbe6;
  color: #faad14;
  border: 1rpx solid #ffe58f;
}

.step-risk.low {
  background: #f6ffed;
  color: #52c41a;
  border: 1rpx solid #b7eb8f;
}

.execute-btn {
  margin-top: 10rpx;
  width: 100%;
}

/* 系统消息 */
.system-message {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  margin: 0 auto;
  max-width: 80%;
  font-size: 24rpx;
  color: #666;
}

.system-icon {
  font-size: 20rpx;
}

.system-text {
  flex: 1;
}

/* 正在输入指示器 */
.typing-indicator {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: white;
  border-radius: 20rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #1890ff;
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.typing-text {
  font-size: 24rpx;
  color: #666;
}

/* 输入区域 */
.input-area {
  background: white;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #e8e8e8;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.message-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  min-height: 60rpx;
}

.send-btn {
  background: #1890ff;
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.send-btn.disabled {
  background: #d9d9d9;
  color: #999;
}

.send-btn:not(.disabled):active {
  opacity: 0.8;
  transform: scale(0.98);
}