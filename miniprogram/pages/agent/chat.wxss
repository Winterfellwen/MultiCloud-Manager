/* pages/agent/chat.wxss - AI Agent 对话样式 */
.chat-container {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: var(--bg);
}

.chat-header {
  background: var(--primary);
  color: white;
  padding: 20rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.1);
  z-index: 100;
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
}

.mode-picker {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  padding: 10rpx 20rpx;
}

.mode-display {
  font-size: 24rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.icon-arrow {
  font-size: 20rpx;
  opacity: 0.8;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.messages {
  display: flex;
  flex-direction: column;
  gap: 30rpx;
}

.message {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
}

.message.user {
  justify-content: flex-end;
}

.message.assistant {
  justify-content: flex-start;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.user-avatar {
  order: 2;
}

.ai-avatar {
  order: 1;
}

.message-bubble {
  max-width: 70%;
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-word;
}

.user-bubble {
  background: var(--primary);
  color: white;
  border-bottom-right-radius: 4rpx;
  order: 1;
}

.ai-bubble {
  background: var(--surface);
  color: var(--text);
  border-bottom-left-radius: 4rpx;
  box-shadow: var(--shadow);
  order: 2;
}

.plan-card {
  margin-top: 20rpx;
  border: 1rpx solid var(--border);
  border-radius: var(--radius-lg);
  padding: 20rpx;
  background: var(--surface-hover);
}

.plan-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 10rpx;
  border-bottom: 1rpx solid var(--border);
}

.plan-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text);
  flex: 1;
}

.plan-risk {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
}

.plan-risk.high {
  background: var(--danger);
  color: white;
}

.plan-risk.medium {
  background: var(--warning);
  color: white;
}

.plan-risk.low {
  background: var(--success);
  color: white;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.step-item {
  background: var(--surface);
  border-radius: var(--radius);
  padding: 16rpx;
  border-left: 8rpx solid var(--border);
}

.step-item.high {
  border-left-color: var(--danger);
}

.step-item.medium {
  border-left-color: var(--warning);
}

.step-item.low {
  border-left-color: var(--success);
}

.step-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.step-index {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.step-action {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text);
}

.step-details {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  word-break: break-all;
}

.step-risk {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  display: inline-block;
}

.step-risk.high {
  background: rgba(239, 68, 68, 0.1);
  color: var(--danger);
  border: 1rpx solid rgba(239, 68, 68, 0.3);
}

.step-risk.medium {
  background: rgba(245, 158, 11, 0.1);
  color: var(--warning);
  border: 1rpx solid rgba(245, 158, 11, 0.3);
}

.step-risk.low {
  background: rgba(34, 197, 94, 0.1);
  color: var(--success);
  border: 1rpx solid rgba(34, 197, 94, 0.3);
}

.execute-btn {
  margin-top: 10rpx;
  width: 100%;
}

.system-message {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: var(--surface-hover);
  border-radius: 20rpx;
  padding: 12rpx 24rpx;
  margin: 0 auto;
  max-width: 80%;
  font-size: 24rpx;
  color: var(--text-secondary);
}

.system-icon {
  font-size: 20rpx;
}

.system-text {
  flex: 1;
}

.typing-indicator {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: var(--surface);
  border-radius: 20rpx;
  padding: 20rpx;
  margin: 20rpx 0;
  box-shadow: var(--shadow);
}

.typing-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: var(--primary);
  border-radius: 50%;
  animation: typing 1.4s infinite ease-in-out;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }

@keyframes typing {
  0%, 80%, 100% { transform: scale(0.8); opacity: 0.5; }
  40% { transform: scale(1); opacity: 1; }
}

.typing-text {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.input-area {
  background: var(--surface);
  padding: 20rpx 30rpx;
  border-top: 1rpx solid var(--border);
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.message-input {
  flex: 1;
  background: var(--bg);
  border-radius: 30rpx;
  padding: 20rpx 30rpx;
  font-size: 28rpx;
  min-height: 60rpx;
  color: var(--text);
}

.send-btn {
  background: var(--primary);
  color: white;
  border: none;
  border-radius: 30rpx;
  padding: 20rpx 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  transition: all 0.2s;
}

.send-btn.disabled {
  background: var(--border);
  color: var(--text-secondary);
}

.send-btn:not(.disabled):active {
  opacity: 0.8;
  transform: scale(0.98);
}

.header-actions {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-btn {
  width: 56rpx;
  height: 56rpx;
  line-height: 56rpx;
  text-align: center;
  background: rgba(255,255,255,0.2);
  border-radius: 50%;
  font-size: 28rpx;
}

.quick-actions-bar {
  background: var(--surface);
  padding: 16rpx 30rpx;
  display: flex;
  gap: 16rpx;
  border-bottom: 1rpx solid var(--border);
}

.qa-btn {
  flex: 1;
  background: var(--primary);
  color: #fff;
  font-size: 24rpx;
  padding: 12rpx 0;
  border-radius: var(--radius-sm);
  border: none;
  text-align: center;
}

.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0,0,0,0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.modal-content {
  width: 84%;
  max-height: 80vh;
  background: var(--surface);
  border-radius: var(--radius-lg);
  overflow-y: auto;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid var(--border);
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--text);
}

.modal-close {
  font-size: 36rpx;
  color: var(--text-secondary);
  padding: 8rpx;
}

.modal-body {
  padding: 30rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: var(--text);
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  background: var(--bg);
  border: 1rpx solid var(--border);
  border-radius: var(--radius-sm);
  padding: 20rpx;
  font-size: 26rpx;
  color: var(--text);
  box-sizing: border-box;
}

.modal-footer {
  padding: 0 30rpx 30rpx;
}

.config-save-btn {
  width: 100%;
  background: var(--primary);
  color: #fff;
  border-radius: var(--radius-sm);
  padding: 20rpx;
  font-size: 28rpx;
  border: none;
}
